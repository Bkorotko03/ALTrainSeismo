   "source": [
    "# now to actually make the PSDs\n",
    "def makePSD(dict = noiseDict,fDict = freqDict):\n",
    "    PSDDict = {}\n",
    "    fGridDict = {}\n",
    "    for label in fDict.keys():\n",
    "        list = dict[label]\n",
    "        PSDDict[label] = []\n",
    "        fGridDict[label] = []\n",
    "        for i in range(len(list)):\n",
    "            fGrid,psd = welch(list[i],fs=freqDict[label],nperseg=defNper)\n",
    "            PSDDict[label].append(psd)\n",
    "            fGridDict[label].append(fGrid)\n",
    "    \n",
    "    return PSDDict,fGridDict"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 143,
   "id": "e23df980",
   "metadata": {},
   "outputs": [],
   "source": [
    "PSDDict,fGridDict = makePSD()"
   ]
  },
