   "source": [
    "def downSamp(nArr = noiseArrs,fd=freqDict):\n",
    "    noiseDict = {}\n",
    "    for label in fd.keys():\n",
    "        f = fd[label]\n",
    "        skipNum = int(defFreq / f)\n",
    "        # print(type(skipNum))\n",
    "        noiseDict[label] = []\n",
    "        for i in range(len(nArr)):\n",
    "            downArr = nArr[i][::skipNum]\n",
    "            noiseDict[label].append(downArr)\n",
    "    return noiseDict"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 139,
   "id": "88c313dc",
   "metadata": {},
   "outputs": [],
   "source": [
    "noiseDict = downSamp()"
   ]
